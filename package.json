{
  "name": "vscode-sessions-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta npm:dev:api npm:dev:web",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -p tsconfig.app.json --noEmit && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "start": "node dist/server/index.js"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "fast-glob": "^3.3.3",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
